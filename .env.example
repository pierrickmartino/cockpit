# PostgreSQL connection string used by the app and the Postgres contract test.
# When unset, the Postgres half of the repository contract suite is skipped.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cockpit

# Shared secret that authenticates the Admin on authoring/generation/publish
# routes (the single admin-vs-public trust boundary, per ADR-0009). Presented as
# an `Authorization: Bearer <token>` header. When unset, the guard fails closed:
# every request is treated as public and authoring routes deny all callers.
ADMIN_TOKEN=dev-admin-token
